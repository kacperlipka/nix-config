{
  "name": "Nix Development Environment",
  "image": "ubuntu:22.04",

  "features": {
    "ghcr.io/devcontainers/features/nix:1": {}
  },

  "postCreateCommand": "bash -c 'curl -fsSL https://raw.githubusercontent.com/kacperlipka/nix-config/main/.devcontainer/setup.sh | bash'",

  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  }
}